COMPOSE_PROJECT_NAME=golf-tracer

FRONTEND_PORT=7070
BACKEND_PORT=7075

# Use your public origin when testing from a phone.
VITE_API_BASE_URL=http://borseth.ddns.net:7075
CORS_ORIGINS=["http://borseth.ddns.net:7070","http://localhost:3000"]

MODEL_PATH=/app/models/yolov11s-golf-ball.pt
UPLOAD_DIR=/app/uploads
OUTPUT_DIR=/app/outputs
JOB_STORE_DIR=/app/job-store
MAX_UPLOAD_MB=1024
YOLO_DEVICE=0
YOLO_CONFIDENCE=0.25
REQUIRE_CUDA=true
