COMPOSE_PROJECT_NAME=golf-tracer

FRONTEND_PORT=3000
BACKEND_PORT=8000

VITE_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

MODEL_PATH=/app/models/yolov11s-golf-ball.pt
UPLOAD_DIR=/app/uploads
OUTPUT_DIR=/app/outputs
JOB_STORE_DIR=/app/job-store
MAX_UPLOAD_MB=512
YOLO_DEVICE=0
YOLO_CONFIDENCE=0.25
REQUIRE_CUDA=false

TRACKER_MAX_GAP_FRAMES=12
TRACKER_DETECTION_GATE_PX=120
TRACKER_OPTICAL_FLOW_GATE_PX=80
TRACKER_SMOOTH_WINDOW=5
TRACKER_STATIONARY_ADDRESS_FRAMES=4
TRACKER_STATIONARY_ADDRESS_RADIUS_PX=8
TRACKER_SWING_MOTION_ROI_PX=140
TRACKER_SWING_LAUNCH_SPEED_PX=7
TRACKER_STALE_TRACK_FRAMES=30
TRACKER_STALE_TRACK_RADIUS_PX=80
TRACKER_SYNTHETIC_LAUNCH_FRAMES=45
TRACKER_SYNTHETIC_LAUNCH_UPWARD_BIAS=0.85
TRACKER_CAMERA_MOTION_COMPENSATION=true
TRACKER_CAMERA_MOTION_MAX_PX=35
TRACKER_IMPACT_DETECTION=true
TRACKER_IMPACT_PRE_ROLL_FRAMES=2
TRACKER_POST_IMPACT_STALE_FRAMES=4

TRACER_THICKNESS=8
TRACER_TAIL_FRAMES=90
TRACER_HORIZON_RATIO=0.42
