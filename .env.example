COMPOSE_PROJECT_NAME=golf-tracer

FRONTEND_PORT=3000
BACKEND_PORT=8000

VITE_API_BASE_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

MODEL_PATH=/app/models/yolov11s-golf-ball.pt
UPLOAD_DIR=/app/uploads
OUTPUT_DIR=/app/outputs
JOB_STORE_DIR=/app/job-store
MAX_UPLOAD_MB=512
YOLO_DEVICE=0
YOLO_CONFIDENCE=0.25
REQUIRE_CUDA=false
